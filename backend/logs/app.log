            "text": "```json\n{\n  \"questions\": [\n    {\n      \"question\": \"LANとは何の略語ですか？\",\n      \"answer\": \"Local Area Network\",\n      \"description\": \"ローカルエリアネットワーク。小規模な範囲のネットワーク。\"\n    },\n    {\n      \"question\": \"LANで用いられる代表的な通信規格は？\",\n      \"answer\": \"Ethernet\",\n      \"description\": \"LANの標準規格。様々な速度やケーブルに対応。\"\n    },\n    {\n      \"question\": \"EthernetはIPアドレスで通信しますか？\",\n      \"answer\": \"いいえ、MACアドレスです\",\n      \"description\": \"IPアドレスは論理アドレス。MACアドレスは物理アドレス。\"\n    },\n    {\n      \"question\": \"MACアドレスはどのように割り当てられますか？\",\n      \"answer\": \"NIC(Network Interface Card)ごとに割り当て\",\n      \"description\": \"ネットワークカードに固有の物理アドレス。\"\n    },\n    {\n      \"question\": \"IPアドレスからMACアドレスを取得するプロトコルは？\",\n      \"answer\": \"ARP(Address Resolution Protocol)\",\n      \"description\": \"IPアドレスをMACアドレスに変換するプロトコル。\"\n    },\n    {\n      \"question\": \"ARPで用いられる通信方式は？\",\n      \"answer\": \"ブロードキャスト\",\n      \"description\": \"ARPリクエストはブロードキャストで送信される。\"\n    },\n    {\n      \"question\": \"ブロードキャストの到達範囲を制限するものは？\",\n      \"answer\": \"セグメント\",\n      \"description\": \"物理的な範囲で通信を制限するセグメント化。\"\n    },\n    {\n      \"question\": \"Ethernet規格の1000BASE-LXで「LX」は何を表すか？\",\n      \"answer\": \"長波長光ファイバ\",\n      \"description\": \"光ファイバの種類を表す識別子。距離や速度に関係。\"\n    },\n    {\n      \"question\": \"1000BASE-LXの「1000」は何を表すか？\",\n      \"answer\": \"1Gbps\",\n      \"description\": \"伝送速度を表す。1000Mbps=1Gbps。\"\n    },\n    {\n      \"question\": \"初期のEthernetで用いられた接続方法は？\",\n      \"answer\": \"バス型接続\",\n      \"description\": \"一本のケーブルに全ての機器が接続される方式。\"\n    },\n    {\n      \"question\": \"バス型接続の欠点は？\",\n      \"answer\": \"拡張性に乏しい\",\n      \"description\": \"ケーブル一本なので拡張が困難で、衝突も起きやすい。\"\n    },\n    {\n      \"question\": \"現在の主流となっているLANの構成方法は？\",\n      \"answer\": \"スイッチネットワーク\",\n      \"description\": \"スイッチングハブを用いた効率的な接続方法。\"\n    },\n    {\n      \"question\": \"10BASE-5で使用されるケーブルの種類は？\",\n      \"answer\": \"同軸ケーブル\",\n      \"description\": \"太いケーブルで、比較的長距離に対応できた。\"\n    },\n    {\n      \"question\": \"100BASE-TXで使用されるケーブルの種類は？\",\n      \"answer\": \"ツイストペアケーブル\",\n      \"description\": \"より線ケーブル。ノイズに強く、現在主流。\"\n    },\n    {\n      \"question\": \"同軸ケーブルの接続方法として「切って挟み込む」以外に何がある？\",\n      \"answer\": \"バンパイア接続\",\n      \"description\": \"ケーブルに穴を開けて接続する手法。現在は少ない。\"\n    },\n    {\n      \"question\": \"ツイストペアケーブルの利点は？\",\n      \"answer\": \"ノイズに強い、敷設が容易\",\n      \"description\": \"ノイズ対策が施されており、扱いやすいケーブル。\"\n    },\n    {\n      \"question\": \"UTPとは何の略語ですか？\",\n      \"answer\": \"Unshielded Twisted Pair Cable\",\n      \"description\": \"シールドされていないツイストペアケーブル。\"\n    },\n    {\n      \"question\": \"光ファイバケーブルのコアとクラッドの屈折率は？\",\n      \"answer\": \"コア\u003eクラッド\",\n      \"description\": \"屈折率の違いにより光がコアに閉じ込められる。\"\n    },\n    {\n      \"question\": \"光ファイバケーブルの種類で、長距離伝送に向いているものは？\",\n      \"answer\": \"シングルモード\",\n      \"description\": \"コアが細く、長距離伝送に適している。\"\n    },\n    {\n      \"question\": \"光ファイバケーブルの種類で、安価なものといえば？\",\n      \"answer\": \"マルチモード\",\n      \"description\": \"コアが太く、短距離伝送に適している。\"\n    },\n    {\n      \"question\": \"ハブ(Hub)の機能は？\",\n      \"answer\": \"受信した信号を全ポートに送信\",\n      \"description\": \"全ポートにブロードキャストする単純な機器。\"\n    },\n    {\n      \"question\": \"ハブを複数接続する方式を何というか？\",\n      \"answer\": \"カスケード接続\",\n      \"description\": \"ツリー状にハブを接続する方式。\"\n    },\n    {\n      \"question\": \"ハブで接続された範囲は？\",\n      \"answer\": \"同一セグメント\",\n      \"description\": \"ハブで接続された機器は同じブロードキャストドメインに属する。\"\n    },\n    {\n      \"question\": \"大規模LANにおけるハブの課題は？\",\n      \"answer\": \"ブロードキャストストーム\",\n      \"description\": \"ループ構成でブロードキャストが無限に増幅する現象。\"\n    },\n    {\n      \"question\": \"ブロードキャストストームを防ぐプロトコルは？\",\n      \"answer\": \"STP(Spanning Tree Protocol)\",\n      \"description\": \"ループを検知し、一部ポートを無効化してループを解消する。\"\n    },\n    {\n      \"question\": \"STPで用いられる制御フレームは？\",\n      \"answer\": \"BPDU(Bridge Protocol Data Unit)\",\n      \"description\": \"スイッチ間で交換される制御フレーム。\"\n    },\n    {\n      \"question\": \"L2スイッチの問題点の一つは？\",\n      \"answer\": \"MACブロードキャストの抑制が難しい\",\n      \"description\": \"ブロードキャストを抑制できないため、大規模化に課題がある。\"\n    },\n    {\n      \"question\": \"大規模LANにおける課題を解決する技術は？\",\n      \"answer\": \"VLAN(Virtual LAN)\",\n      \"description\": \"論理的にネットワークを分割し、ブロードキャストを制限する。\"\n    },\n    {\n      \"question\": \"VLANの種類で、ポート単位でVLANを割り当てるものは？\",\n      \"answer\": \"Port VLAN\",\n      \"description\": \"シンプルだが、ポートの使い方が制限される。\"\n    },\n    {\n      \"question\": \"VLANの種類で、MACフレームにVLAN番号(tag)を付加するものは？\",\n      \"answer\": \"Tagged VLAN\",\n      \"description\": \"柔軟なVLAN構成が可能だが、機器が高価になる。\"\n    },\n    {\n      \"question\": \"Tagged VLANでは、MACフレームに何が付加されますか？\",\n      \"answer\": \"VLANタグ\",\n      \"description\": \"VLANタグにより、複数のVLANに所属させることができる。\"\n    }\n  ]\n}\n```"
